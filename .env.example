# Copy to .env for local development. Never commit the real .env.
# In production, set these as GitHub Actions repository secrets instead.

# From @BotFather after creating your bot.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Your personal chat id. Easiest way to find it: message your bot, then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates and read message.chat.id
TELEGRAM_CHAT_ID=123456789

# OPTIONAL — only needed if you enable the LinkedIn (email ingestion) source.
# Mailbox that receives your LinkedIn Job-Alert emails. For Gmail, create an
# "App Password" (Account → Security → App passwords) and use it here, not your
# normal password. IMAP host/folder are set in config.yaml (sources.linkedin).
IMAP_USERNAME=you@gmail.com
IMAP_PASSWORD=your-app-password
