# Copy to .env for local development. Never commit the real .env.
# In production, set these as GitHub Actions repository secrets instead.

# From @BotFather after creating your bot.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Your personal chat id. Easiest way to find it: message your bot, then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates and read message.chat.id
TELEGRAM_CHAT_ID=123456789
